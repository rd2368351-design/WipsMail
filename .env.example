WISPMAIL_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=console
API_HOST=0.0.0.0
API_PORT=8080
API_READ_TIMEOUT=30s
API_WRITE_TIMEOUT=60s
API_SHUTDOWN_TIMEOUT=30s
SMTP_HOST=0.0.0.0
SMTP_PORT=2525
SMTP_TLS_CERT=./certs/localhost.crt
SMTP_TLS_KEY=./certs/localhost.key
SMTP_MAX_MESSAGE_SIZE=26214400
IMAP_HOST=0.0.0.0
IMAP_PORT=993
IMAP_TLS_CERT=./certs/localhost.crt
IMAP_TLS_KEY=./certs/localhost.key
POP3_HOST=0.0.0.0
POP3_PORT=995
POP3_TLS_CERT=./certs/localhost.crt
POP3_TLS_KEY=./certs/localhost.key
JMAP_HOST=0.0.0.0
JMAP_PORT=443
JMAP_TLS_CERT=./certs/localhost.crt
JMAP_TLS_KEY=./certs/localhost.key
DATABASE_URL=postgres://wispmail:wispmail@localhost:5432/wispmail?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=wispmail
JWT_SECRET=change_this_to_random_64_character_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=wispmail
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=wispmail-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
DKIM_SELECTOR=default
DKIM_DOMAIN=wispmail.local
DKIM_PRIVATE_KEY_PATH=./certs/dkim_private.pem
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=wispmail
OTEL_SERVICE_VERSION=1.0.0
METRICS_PATH=/metrics
HEALTH_PATH=/healthz
READY_PATH=/readyz
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
ETCD_ENDPOINTS=localhost:2379
ETCD_DIAL_TIMEOUT=5s
CLUSTER_NAME=wispmail
CLUSTER_NODE_ID=node-1
CLUSTER_BIND_ADDR=0.0.0.0
CLUSTER_BIND_PORT=7946
CLUSTER_ADVERTISE_ADDR=127.0.0.1
CLUSTER_ADVERTISE_PORT=7946
GRPC_PORT=9090