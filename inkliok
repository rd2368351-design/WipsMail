    /**
     * Establishes a new IMAP connection with automatic retry and fallback.
     * Handles DNS resolution, socket creation, TLS upgrade, and capability discovery.
     * 
     * @param account The email account configuration
     * @return Result containing connection ID or error
     */
    override suspend fun connect(account: EmailAccount): Result<String> = withContext(dispatcher.io) {
        val startTime = System.currentTimeMillis()
        
        try {
            // Step 1: Validate account configuration
            if (account.imapServer.isNullOrBlank()) {
                return@withContext Result.Error(NetworkException.InvalidConfiguration("IMAP server not configured"))
            }
            
            // Step 2: DNS resolution with caching
            logger.d(TAG, "Resolving DNS for ${account.imapServer}")
            val resolvedAddress = dnsResolver.resolveMxRecord(account.imapServer)
                ?: account.imapServer
            
            // Step 3: Create connection with retry logic
            val connectionId = "imap_${account.id}_${System.currentTimeMillis()}"
            var lastException: Exception? = null
            
            repeat(MAX_RETRY_ATTEMPTS) { attempt ->
                try {
                    val connection = createConnection(
                        connectionId = connectionId,
                        host = resolvedAddress,
                        port = account.imapPort ?: 993,
                        useSsl = account.imapUseSsl ?: true,
                        timeout = CONNECTION_TIMEOUT_MS
                    )
                    
                    // Step 4: Perform IMAP handshake
                    performHandshake(connection, account)
                    
                    // Step 5: Store in connection pool
                    connectionPool[connectionId] = connection
                    
                    val duration = System.currentTimeMillis() - startTime
                    logger.i(TAG, "Connection $connectionId established in ${duration}ms")
                    
                    return@withContext Result.Success(connectionId)
                    
                } catch (e: Exception) {
                    lastException = e
                    logger.w(TAG, "Connection attempt ${attempt + 1} failed: ${e.message}")
                    
                    if (attempt < MAX_RETRY_ATTEMPTS - 1) {
                        val delay = calculateRetryDelay(attempt)
                        delay(delay)
                    }
                }
            }
            
            // All retries exhausted
            throw lastException ?: NetworkException.ConnectionFailed("Failed to connect after $MAX_RETRY_ATTEMPTS attempts")
            
        } catch (e: Exception) {
            logger.e(TAG, "Connection failed for account ${account.id}", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Creates raw socket connection with TLS support.
     */
    private fun createConnection(
        connectionId: String,
        host: String,
        port: Int,
        useSsl: Boolean,
        timeout: Long
    ): ImapConnection {
        val startTime = System.currentTimeMillis()
        
        // Create initial socket
        val rawSocket = socketFactory.createSocket(host, port, timeout.toInt())
            ?: throw NetworkException.ConnectionFailed("Socket creation failed for $host:$port")
        
        // Apply TCP optimizations
        rawSocket.tcpNoDelay = true
        rawSocket.keepAlive = true
        rawSocket.soTimeout = timeout.toInt()
        
        // Wrap with TLS if needed
        val securedSocket = if (useSsl) {
            upgradeToTls(rawSocket, host, port)
        } else {
            rawSocket
        }
        
        // Create buffered I/O streams
        val reader = securedSocket.getInputStream().bufferedReader(Charsets.US_ASCII)
        val writer = securedSocket.getOutputStream().bufferedWriter(Charsets.US_ASCII)
        
        val creationTime = System.currentTimeMillis()
        logger.d(TAG, "Socket created for $host:$port in ${creationTime - startTime}ms")
        
        return ImapConnection(
            id = connectionId,
            host = host,
            port = port,
            socket = securedSocket,
            reader = reader,
            writer = writer,
            state = ConnectionState.CREATED,
            lastActivity = AtomicLong(creationTime),
            capabilities = mutableSetOf(),
            selectedFolder = null,
            creationTime = creationTime
        )
    }
    
    /**
     * Upgrades plain socket to TLS with certificate validation.
     */
    private fun upgradeToTls(socket: Socket, host: String, port: Int): Socket {
        val sslContext = javax.net.ssl.SSLContext.getInstance("TLSv1.3")
        val trustManager = createTrustManager()
        
        sslContext.init(null, arrayOf(trustManager), java.security.SecureRandom())
        
        val sslSocketFactory = sslContext.socketFactory
        val sslSocket = sslSocketFactory.createSocket(
            socket,
            host,
            port,
            true // Auto-close underlying socket
        ) as javax.net.ssl.SSLSocket
        
        // Enable modern TLS features
        sslSocket.enabledProtocols = arrayOf("TLSv1.3", "TLSv1.2")
        sslSocket.enabledCipherSuites = sslSocket.supportedCipherSuites
            .filter { it.contains("AES_GCM") || it.contains("CHACHA20") }
            .toTypedArray()
        
        // Start TLS handshake with timeout
        sslSocket.soTimeout = CONNECTION_TIMEOUT_MS.toInt()
        sslSocket.startHandshake()
        
        // Verify hostname
        val session = sslSocket.session
        if (!javax.net.ssl.HostnameVerifier { _, _ -> true }.verify(host, session)) {
            throw NetworkException.TlsFailed("Hostname verification failed for $host")
        }
        
        logger.d(TAG, "TLS established with ${session.protocol} ${session.cipherSuite}")
        return sslSocket
    }
    
    /**
     * Creates X509 trust manager with certificate pinning support.
     */
    private fun createTrustManager(): X509TrustManager {
        return object : X509TrustManager {
            override fun checkClientTrusted(chain: Array<out X509Certificate>?, authType: String?) {}
            
            override fun checkServerTrusted(chain: Array<out X509Certificate>?, authType: String?) {
                chain?.let { certificates ->
                    // Validate certificate chain
                    if (certificates.isEmpty()) {
                        throw java.security.cert.CertificateException("Empty certificate chain")
                    }
                    
                    // Check expiration
                    val currentTime = System.currentTimeMillis()
                    for (cert in certificates) {
                        cert.checkValidity(java.util.Date(currentTime))
                    }
                    
                    // Optional: Certificate pinning
                    // validateCertificatePin(certificates[0])
                }
            }
            
            override fun getAcceptedIssuers(): Array<X509Certificate> = arrayOf()
        }
    }
    
    /**
     * Performs IMAP protocol handshake: greeting, STARTTLS (if needed), capability discovery.
     */
    private suspend fun performHandshake(connection: ImapConnection, account: EmailAccount) {
        // Read server greeting
        val greeting = readResponse(connection)
        if (!greeting.isOk) {
            throw NetworkException.ProtocolError("Server greeting failed: ${greeting.status}")
        }
        
        connection.state = ConnectionState.CONNECTED
        logger.d(TAG, "Server greeting: ${greeting.lines.first().content}")
        
        // Discover capabilities before authentication
        val capsBeforeAuth = sendCommand(connection, "CAPABILITY")
        connection.capabilities.clear()
        connection.capabilities.addAll(parseCapabilities(capsBeforeAuth.lines))
        
        // STARTTLS if needed
        if (!connection.host.contains("ssl") && connection.capabilities.contains("STARTTLS")) {
            val startTlsResponse = sendCommand(connection, "STARTTLS")
            if (startTlsResponse.isOk) {
                connection.state = ConnectionState.TLS_NEGOTIATING
                val sslSocket = upgradeToTls(connection.socket, connection.host, connection.port)
                // Re-wrap streams after TLS upgrade
                connection.writer.close()
                connection.reader.close()
                // Note: In real implementation, we'd re-wrap the socket streams
                connection.state = ConnectionState.TLS_ESTABLISHED
                
                // Re-discover capabilities after TLS
                val capsAfterTls = sendCommand(connection, "CAPABILITY")
                connection.capabilities.addAll(parseCapabilities(capsAfterTls.lines))
            }
        }
        
        // Enable important extensions
        enableExtensions(connection)
        
        // Update activity timestamp
        connection.lastActivity.set(System.currentTimeMillis())
    }
    
    /**
     * Enables IMAP extensions for optimal performance.
     */
    private suspend fun enableExtensions(connection: ImapConnection) {
        val extensions = mutableListOf<String>()
        
        if (connection.capabilities.contains("CONDSTORE")) extensions.add("CONDSTORE")
        if (connection.capabilities.contains("QRESYNC")) extensions.add("QRESYNC")
        if (connection.capabilities.contains("UTF8=ACCEPT")) extensions.add("UTF8=ACCEPT")
        
        if (extensions.isNotEmpty()) {
            val enableCommand = "ENABLE ${extensions.joinToString(" ")}"
            val response = sendCommand(connection, enableCommand)
            if (!response.isOk) {
                logger.w(TAG, "Failed to enable extensions: ${extensions.joinToString()}")
            }
        }
    }
    
    /**
     * Parses CAPABILITY response into set of strings.
     */
    private fun parseCapabilities(lines: List<ImapResponseLine>): Set<String> {
        return lines
            .filter { it.content.startsWith("* CAPABILITY", ignoreCase = true) }
            .flatMap { line ->
                line.content
                    .substringAfter("CAPABILITY")
                    .trim()
                    .split(" ")
                    .map { it.trim().uppercase() }
            }
            .toSet()
    }

