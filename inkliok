    /**
     * Stores/updates message flags with support for CONDSTORE.
     */
    override suspend fun storeFlags(
        connectionId: String,
        folderName: String,
        uidRange: List<Long>,
        flags: List<String>,
        operation: FlagOperation
    ): Result<Boolean> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            // Build flag string
            val flagStr = buildFlagString(flags, operation)
            val sequenceSet = formatSequenceSet(uidRange)
            
            val storeCommand = buildString {
                append("UID STORE $sequenceSet ")
                append(if (operation == FlagOperation.REPLACE) "" else "${operation.imapPrefix}")
                append("FLAGS ")
                append(if (operation == FlagOperation.ADD_SILENT || operation == FlagOperation.REMOVE_SILENT) {
                    "($flagStr)"
                } else {
                    "($flagStr)"
                })
                
                // Add UNCHANGEDSINCE for CONDSTORE
                if (connection.capabilities.contains("CONDSTORE")) {
                    append(" UNCHANGEDSINCE ${System.currentTimeMillis() / 1000}")
                }
            }
            
            val response = sendCommand(connection, storeCommand)
            
            if (response.isOk) {
                logger.d(TAG, "Flags ${operation.name} successful for ${uidRange.size} messages")
            }
            
            Result.Success(response.isOk)
            
        } catch (e: Exception) {
            logger.e(TAG, "Flag operation failed", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Marks messages as read.
     */
    override suspend fun markAsRead(
        connectionId: String,
        folderName: String,
        uid: List<Long>
    ): Result<Boolean> = storeFlags(connectionId, folderName, uid, listOf("\\Seen"), FlagOperation.ADD)
    
    /**
     * Marks messages as unread.
     */
    override suspend fun markAsUnread(
        connectionId: String,
        folderName: String,
        uid: List<Long>
    ): Result<Boolean> = storeFlags(connectionId, folderName, uid, listOf("\\Seen"), FlagOperation.REMOVE)
    
    /**
     * Flags messages as important.
     */
    override suspend fun markAsFlagged(
        connectionId: String,
        folderName: String,
        uid: List<Long>
    ): Result<Boolean> = storeFlags(connectionId, folderName, uid, listOf("\\Flagged"), FlagOperation.ADD)
    
    /**
     * Marks messages as answered.
     */
    override suspend fun markAsAnswered(
        connectionId: String,
        folderName: String,
        uid: List<Long>
    ): Result<Boolean> = storeFlags(connectionId, folderName, uid, listOf("\\Answered"), FlagOperation.ADD)
    
    /**
     * Deletes messages (moves to Trash with \\Deleted flag).
     */
    override suspend fun deleteMessages(
        connectionId: String,
        folderName: String,
        uid: List<Long>
    ): Result<Boolean> {
        // Add \Deleted flag
        val deleted = storeFlags(connectionId, folderName, uid, listOf("\\Deleted"), FlagOperation.ADD)
        if (deleted is Result.Error) return deleted
        
        // Expunge to permanently remove
        return expungeFolder(connectionId, folderName)
    }
    
    /**
     * Expunges deleted messages from folder.
     */
    override suspend fun expungeFolder(
        connectionId: String,
        folderName: String
    ): Result<Boolean> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            val command = if (connection.capabilities.contains("UIDPLUS")) {
                "UID EXPUNGE 1:*" // Selective expunge
            } else {
                "EXPUNGE"
            }
            
            val response = sendCommand(connection, command)
            Result.Success(response.isOk)
            
        } catch (e: Exception) {
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Builds flag string for STORE command.
     */
    private fun buildFlagString(flags: List<String>, operation: FlagOperation): String {
        return flags.joinToString(" ") { flag ->
            when (operation) {
                FlagOperation.ADD -> "+$flag"
                FlagOperation.REMOVE -> "-$flag"
                FlagOperation.ADD_SILENT -> "+$flag"
                FlagOperation.REMOVE_SILENT -> "-$flag"
                FlagOperation.REPLACE -> flag
            }
        }
    }

