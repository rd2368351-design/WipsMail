    /**
     * Moves messages between folders using MOVE command or COPY+DELETE fallback.
     */
    override suspend fun moveMessages(
        connectionId: String,
        sourceFolder: String,
        targetFolder: String,
        uid: List<Long>
    ): Result<Boolean> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            val sequenceSet = formatSequenceSet(uid)
            
            if (connection.capabilities.contains("MOVE")) {
                // Use native MOVE command (RFC 6851)
                val moveCommand = "UID MOVE $sequenceSet \"$targetFolder\""
                val response = sendCommand(connection, moveCommand)
                Result.Success(response.isOk)
                
            } else {
                // Fallback: COPY + STORE \\Deleted + EXPUNGE
                val copyCommand = "UID COPY $sequenceSet \"$targetFolder\""
                val copyResponse = sendCommand(connection, copyCommand)
                
                if (!copyResponse.isOk) {
                    return@withContext Result.Error(NetworkException.ServerError("Copy failed: ${copyResponse.status}"))
                }
                
                // Mark original as deleted
                val deleteResponse = storeFlags(
                    connectionId, sourceFolder, uid,
                    listOf("\\Deleted"), FlagOperation.ADD
                )
                
                if (deleteResponse is Result.Error) return@withContext deleteResponse
                
                // Expunge original folder
                expungeFolder(connectionId, sourceFolder)
            }
            
        } catch (e: Exception) {
            logger.e(TAG, "Move messages failed", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Copies messages to another folder.
     */
    override suspend fun copyMessages(
        connectionId: String,
        sourceFolder: String,
        targetFolder: String,
        uid: List<Long>
    ): Result<Boolean> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            val sequenceSet = formatSequenceSet(uid)
            val copyCommand = "UID COPY $sequenceSet \"$targetFolder\""
            val response = sendCommand(connection, copyCommand)
            
            Result.Success(response.isOk)
            
        } catch (e: Exception) {
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Appends a message to a folder (used for saving drafts, sent mail).
     */
    override suspend fun appendMessage(
        connectionId: String,
        folderName: String,
        messageData: ByteArray,
        flags: List<String>,
        internalDate: String?
    ): Result<Long> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            val literalSize = messageData.size
            
            val appendCommand = buildString {
                append("APPEND \"$folderName\"")
                
                // Add flags
                if (flags.isNotEmpty()) {
                    append(" (${flags.joinToString(" ")})")
                }
                
                // Add internal date
                if (internalDate != null) {
                    append(" \"$internalDate\"")
                }
                
                // Add literal
                append(" {$literalSize}")
            }
            
            // Send command and wait for continuation
            val response = sendCommand(connection, appendCommand)
            
            if (response.status.contains("+") || response.status.contains("Ready")) {
                // Server ready for literal data
                sendRawData(connection, messageData)
                
                // Read final response
                val finalResponse = readResponse(connection)
                if (finalResponse.isOk) {
                    // Parse UID from APPENDUID response
                    val uid = parseAppendUid(finalResponse.lines)
                    Result.Success(uid)
                } else {
                    Result.Error(NetworkException.ServerError("APPEND failed: ${finalResponse.status}"))
                }
            } else {
                Result.Error(NetworkException.ServerError("APPEND not accepted: ${response.status}"))
            }
            
        } catch (e: Exception) {
            logger.e(TAG, "Append message failed", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Parses APPENDUID response to get assigned UID.
     */
    private fun parseAppendUid(lines: List<ImapResponseLine>): Long {
        for (line in lines) {
            if (line.content.contains("APPENDUID")) {
                val uidPart = line.content.substringAfter("APPENDUID ").trim()
                val uidStr = uidPart.substringAfterLast(" ").trim()
                return uidStr.toLongOrNull() ?: 0L
            }
        }
        return 0L
    }

    // ============================================================================
    // SECTION 8: IDLE MODE - REAL-TIME NOTIFICATIONS (600 lines)
    // ============================================================================
    
    /**
     * Starts IMAP IDLE for real-time push notifications.
     * Maintains IDLE with keep-alive pings every 5 minutes.
     */
    override suspend fun startIdle(
        connectionId: String,
        folderName: String
    ): Flow<MailboxUpdate> = channelFlow {
        val connection = getConnection(connectionId)
        if (connection == null) {
            close(NetworkException.ConnectionLost("Connection $connectionId not found"))
            return@channelFlow
        }
        
        // Ensure we're in the correct folder
        if (connection.selectedFolder != folderName) {
            selectFolder(connectionId, folderName, false)
        }
        
        var idleActive = true
        val keepAliveJob = launch {
            while (isActive && idleActive) {
                delay(KEEP_ALIVE_INTERVAL_MS)
                if (idleActive) {
                    sendKeepAlive(connection)
                }
            }
        }
        
        try {
            while (isActive && !connection.socket.isClosed) {
                // Start IDLE
                val idleResponse = sendCommand(connection, "IDLE")
                
                if (idleResponse.status.contains("+") || idleResponse.isOk) {
                    connection.state = ConnectionState.IDLE_ACTIVE
                    idleActive = true
                    
                    // Read IDLE responses
                    while (idleActive && isActive) {
                        val update = readIdleResponse(connection)
                        if (update != null) {
                            send(update)
                        }
                    }
                } else {
                    logger.w(TAG, "IDLE not supported, falling back to polling")
                    // Fall back to polling every 2 minutes
                    delay(120_000)
                    if (isActive) {
                        send(MailboxUpdate(type = UpdateType.POLL_REQUIRED))
                    }
                }
            }
        } catch (e: IOException) {
            logger.e(TAG, "IDLE connection lost", e)
            connection.state = ConnectionState.ERROR
            throw NetworkException.ConnectionLost("IDLE connection lost: ${e.message}")
        } finally {
            idleActive = false
            keepAliveJob.cancel()
            
            // Send DONE to exit IDLE
            try {
                sendRawCommand(connection, "DONE")
                readResponse(connection) // Consume IDLE termination response
            } catch (e: Exception) {
                // Ignore cleanup errors
            }
            
            connection.state = ConnectionState.FOLDER_SELECTED
        }
    }
    
    /**
     * Sends DONE to terminate IDLE mode.
     */
    override suspend fun stopIdle(connectionId: String) {
        val connection = getConnection(connectionId) ?: return
        
        try {
            if (connection.state == ConnectionState.IDLE_ACTIVE) {
                sendRawCommand(connection, "DONE")
                // Read the IDLE termination response
                val response = readResponse(connection)
                connection.state = ConnectionState.FOLDER_SELECTED
                logger.d(TAG, "IDLE stopped: ${response.status}")
            }
        } catch (e: Exception) {
            logger.w(TAG, "Error stopping IDLE: ${e.message}")
        }
    }
    
    /**
     * Sends NOOP command as keep-alive during IDLE.
     */
    private suspend fun sendKeepAlive(connection: ImapConnection) {
        try {
            // Exit IDLE briefly
            sendRawCommand(connection, "DONE")
            val doneResponse = readResponse(connection)
            
            // Send NOOP to keep alive
            val noopResponse = sendCommand(connection, "NOOP")
            connection.lastActivity.set(System.currentTimeMillis())
            
            // Re-enter IDLE
            val resumeCommand = "IDLE"
            val resumeResponse = sendCommand(connection, resumeCommand)
            
            if (resumeResponse.isOk || resumeResponse.status.contains("+")) {
                connection.state = ConnectionState.IDLE_ACTIVE
            }
        } catch (e: Exception) {
            logger.w(TAG, "Keep-alive failed: ${e.message}")
            // Connection will be re-established by the IDLE loop
        }
    }
    
    /**
     * Reads and parses IDLE response updates.
     */
    private suspend fun readIdleResponse(connection: ImapConnection): MailboxUpdate? {
        try {
            val line = readerEngine.readLine(connection.reader) ?: return null
            
            return when {
                line.contains("EXISTS") -> {
                    val count = line.substringBefore(" EXISTS").trim().toIntOrNull() ?: 0
                    MailboxUpdate(type = UpdateType.EXISTS, messageCount = count)
                }
                line.contains("EXPUNGE") -> {
                    val msgNum = line.substringBefore(" EXPUNGE").trim().toIntOrNull() ?: 0
                    MailboxUpdate(type = UpdateType.EXPUNGE, messageNumber = msgNum)
                }
                line.contains("FETCH") -> {
                    // Parse flag changes during IDLE
                    parseIdleFetch(line)
                }
                line.contains("RECENT") -> {
                    val count = line.substringBefore(" RECENT").trim().toIntOrNull() ?: 0
                    MailboxUpdate(type = UpdateType.RECENT, recentCount = count)
                }
                line.contains("BYE") -> {
                    MailboxUpdate(type = UpdateType.SERVER_BYE, error = "Server said BYE")
                }
                else -> null
            }
        } catch (e: IOException) {
            throw e
        } catch (e: Exception) {
            logger.w(TAG, "Error reading IDLE response: ${e.message}")
            null
        }
    }
    
    /**
     * Parses FETCH updates that arrive during IDLE.
     */
    private fun parseIdleFetch(line: String): MailboxUpdate {
        val messageNumber = line.substringBefore(" FETCH").trim().toIntOrNull() ?: 0
        
        val flags = if (line.contains("FLAGS (")) {
            line.substringAfter("FLAGS (").substringBefore(")")
                .split(" ")
                .filter { it.isNotEmpty() }
        } else {
            emptyList()
        }
        
        return MailboxUpdate(
            type = UpdateType.FLAGS_CHANGED,
            messageNumber = messageNumber,
            flags = flags
        )
    }

    // ============================================================================
    // SECTION 9: SEARCH OPERATIONS (400 lines)
    // ============================================================================
    
    /**
     * Searches messages on the server using IMAP SEARCH command.
     */
    override suspend fun searchMessages(
        connectionId: String,
        folderName: String,
        searchCriteria: SearchCriteria
    ): Result<List<Long>> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            // Ensure we're in the correct folder
            if (connection.selectedFolder != folderName) {
                selectFolder(connectionId, folderName, false)
            }
            
            val searchCommand = buildSearchCommand(searchCriteria)
            val response = sendCommand(connection, searchCommand)
            
            if (!response.isOk) {
                return@withContext Result.Error(NetworkException.ServerError("Search failed: ${response.status}"))
            }
            
            // Parse SEARCH results (list of UIDs)
            val messageUids = parseSearchResults(response.lines)
            logger.d(TAG, "Search found ${messageUids.size} messages")
            
            Result.Success(messageUids)
            
        } catch (e: Exception) {
            logger.e(TAG, "Search failed", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Builds IMAP SEARCH command from criteria.
     */
    private fun buildSearchCommand(criteria: SearchCriteria): String {
        val sb = StringBuilder("UID SEARCH ")
        
        // Text search
        if (criteria.text != null) {
            sb.append("TEXT \"${criteria.text}\" ")
        }
        
        // Subject search
        if (criteria.subject != null) {
            sb.append("SUBJECT \"${criteria.subject}\" ")
        }
        
        // From search
        if (criteria.from != null) {
            sb.append("FROM \"${criteria.from}\" ")
        }
        
        // To search
        if (criteria.to != null) {
            sb.append("TO \"${criteria.to}\" ")
        }
        
        // Date criteria
        if (criteria.since != null) {
            sb.append("SINCE ${criteria.since} ")
        }
        if (criteria.before != null) {
            sb.append("BEFORE ${criteria.before} ")
        }
        
        // Flag criteria
        if (criteria.unseen) sb.append("UNSEEN ")
        if (criteria.flagged) sb.append("FLAGGED ")
        if (criteria.answered) sb.append("ANSWERED ")
        if (criteria.deleted) sb.append("DELETED ")
        if (criteria.draft) sb.append("DRAFT ")
        if (criteria.seen) sb.append("SEEN ")
        
        // Size criteria
        if (criteria.largerThan != null) {
            sb.append("LARGER ${criteria.largerThan} ")
        }
        if (criteria.smallerThan != null) {
            sb.append("SMALLER ${criteria.smallerThan} ")
        }
        
        // Header search
        criteria.headers?.forEach { (header, value) ->
            sb.append("HEADER \"$header\" \"$value\" ")
        }
        
        // Combine with logic
        return when (criteria.logic) {
            SearchLogic.AND -> sb.toString().trim()
            SearchLogic.OR -> "OR ${sb.toString().trim()}"
            SearchLogic.NOT -> "NOT ${sb.toString().trim()}"
        }
    }
    
    /**
     * Parses SEARCH response to extract UID list.
     */
    private fun parseSearchResults(lines: List<ImapResponseLine>): List<Long> {
        val uids = mutableListOf<Long>()
        
        for (line in lines) {
            if (line.content.startsWith("* SEARCH")) {
                val numbersStr = line.content.substringAfter("SEARCH").trim()
                val numbers = numbersStr.split(" ")
                    .mapNotNull { it.trim().toLongOrNull() }
                uids.addAll(numbers)
            }
        }
        
        return uids.sorted()
    }

    // ============================================================================
    // SECTION 10: CONNECTION MANAGEMENT & ERROR HANDLING (700 lines)
    // ============================================================================
    
    /**
     * Gets an existing connection by ID.
     */
    private fun getConnection(connectionId: String): ImapConnection? {
        val connection = connectionPool[connectionId] ?: return null
        
        // Check if connection is still valid
        if (connection.socket.isClosed || connection.state == ConnectionState.CLOSED) {
            connectionPool.remove(connectionId)
            return null
        }
        
        return connection
    }
    
    /**
     * Disconnects and cleans up a connection.
     */
    override suspend fun disconnect(connectionId: String) {
        val connection = connectionPool.remove(connectionId) ?: return
        
        try {
            connection.state = ConnectionState.CLOSING
            
            // Exit IDLE if active
            if (connection.state == ConnectionState.IDLE_ACTIVE) {
                try {
                    sendRawCommand(connection, "DONE")
                } catch (_: Exception) {}
            }
            
            // Send LOGOUT
            try {
                sendCommand(connection, "LOGOUT")
            } catch (_: Exception) {}
            
            // Close streams and socket
            try { connection.writer.close() } catch (_: Exception) {}
            try { connection.reader.close() } catch (_: Exception) {}
            try { connection.socket.close() } catch (_: Exception) {}
            
            connection.state = ConnectionState.CLOSED
            logger.i(TAG, "Connection $connectionId disconnected")
            
        } catch (e: Exception) {
            logger.w(TAG, "Error during disconnect: ${e.message}")
        }
    }
    
    /**
     * Sends an IMAP command and reads the response.
     */
    private suspend fun sendCommand(
        connection: ImapConnection,
        command: String
    ): ImapResponse = withTimeout(COMMAND_TIMEOUT_MS) {
        val tag = generateTag()
        val fullCommand = "$tag $command"
        
        // Write command
        writerEngine.writeLine(connection.writer, fullCommand)
        connection.lastActivity.set(System.currentTimeMillis())
        
        logger.v(TAG, "C: $fullCommand")
        
        // Read response
        val response = readResponse(connection, tag)
        logger.v(TAG, "S: ${response.status}")
        
        response
    }
    
    /**
     * Sends raw data without a tag (used for literal data and IDLE DONE).
     */
    private suspend fun sendRawCommand(connection: ImapConnection, data: String) {
        writerEngine.writeLine(connection.writer, data)
        connection.lastActivity.set(System.currentTimeMillis())
        logger.v(TAG, "C: $data")
    }
    
    /**
     * Sends raw binary data (for APPEND literal).
     */
    private suspend fun sendRawData(connection: ImapConnection, data: ByteArray) {
        writerEngine.writeBytes(connection.writer, data)
        connection.lastActivity.set(System.currentTimeMillis())
        logger.v(TAG, "C: <${data.size} bytes of literal data>")
    }
    
    /**
     * Reads IMAP response for a tagged command.
     */
    private suspend fun readResponse(
        connection: ImapConnection,
        tag: String? = null
    ): ImapResponse = withTimeout(COMMAND_TIMEOUT_MS) {
        val lines = mutableListOf<ImapResponseLine>()
        
        while (true) {
            val line = readerEngine.readLine(connection.reader)
                ?: throw NetworkException.ConnectionLost("Connection closed by server")
            
            lines.add(ImapResponseLine(content = line, timestamp = System.currentTimeMillis()))
            
            // Check for completion
            if (tag != null && line.startsWith("$tag ")) {
                break
            }
            
            // Check for untagged completion
            if (tag == null && (line.startsWith("* ") || line.startsWith("+ "))) {
                break
            }
            
            // Handle literal continuation
            if (line.contains("}") && line.endsWith("}")) {
                val literalSize = line.substringAfter("{").substringBefore("}").trim().toIntOrNull()
                if (literalSize != null && literalSize > 0) {
                    val literalData = readerEngine.readBytes(connection.reader, literalSize)
                    lines.add(ImapResponseLine(
                        content = "[LITERAL ${literalSize} bytes]",
                        timestamp = System.currentTimeMillis(),
                        literalData = literalData
                    ))
                }
            }
        }
        
        responseParser.parse(lines, tag)
    }
    
    /**
     * Generates unique command tag.
     */
    private fun generateTag(): String {
        val tagNumber = tagCounter.incrementAndGet()
        if (tagNumber > MAX_TAG_CACHE) {
            tagCounter.set(0)
        }
        return "A${tagNumber.toString().padStart(4, '0')}"
    }
    
    /**
     * Calculates exponential backoff delay for retries.
     */
    private fun calculateRetryDelay(attempt: Int): Long {
        val delay = BASE_RETRY_DELAY_MS * (1L shl attempt)
        return delay.coerceAtMost(MAX_RETRY_DELAY_MS)
    }
    
    /**
     * Maps various exceptions to NetworkException types.
     */
    private fun mapNetworkError(e: Exception): NetworkException {
        return when (e) {
            is NetworkException -> e
            is java.net.SocketTimeoutException -> NetworkException.Timeout(e.message ?: "Connection timed out")
            is java.net.ConnectException -> NetworkException.ConnectionFailed(e.message ?: "Connection refused")
            is java.net.UnknownHostException -> NetworkException.DnsResolutionFailed(e.message ?: "Unknown host")
            is javax.net.ssl.SSLException -> NetworkException.TlsFailed(e.message ?: "TLS handshake failed")
            is java.io.IOException -> NetworkException.ConnectionLost(e.message ?: "IO error")
            else -> NetworkException.Unknown(e.message ?: "Unknown error")
        }
    }
    
    /**
     * Performs health check on a connection.
     */
    override suspend fun healthCheck(connectionId: String): Result<Boolean> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Success(false)
            
            // Check socket status
            if (connection.socket.isClosed) {
                connectionPool.remove(connectionId)
                return@withContext Result.Success(false)
            }
            
            // Send NOOP to verify connection
            if (connection.state == ConnectionState.AUTHENTICATED ||
                connection.state == ConnectionState.FOLDER_SELECTED) {
                val response = sendCommand(connection, "NOOP")
                return@withContext Result.Success(response.isOk)
            }
            
            // Check last activity time
            val idleTime = System.currentTimeMillis() - connection.lastActivity.get()
            if (idleTime > IDLE_TIMEOUT_MS) {
                return@withContext Result.Success(false)
            }
            
            Result.Success(true)
            
        } catch (e: Exception) {
            Result.Success(false)
        }
    }
    
    /**
     * Gets current capabilities for a connection.
     */
    override suspend fun getCapabilities(connectionId: String): Result<Set<String>> {
        val connection = getConnection(connectionId)
            ?: return Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
        
        return Result.Success(connection.capabilities.toSet())
    }
    
    /**
     * Returns current connection statistics.
     */
    override fun getConnectionStats(): Map<String, ConnectionStats> {
        return connectionPool.mapValues { (_, conn) ->
            ConnectionStats(
                id = conn.id,
                host = conn.host,
                state = conn.state.name,
                uptimeMs = System.currentTimeMillis() - conn.creationTime,
                lastActivityMs = System.currentTimeMillis() - conn.lastActivity.get(),
                selectedFolder = conn.selectedFolder,
                capabilities = conn.capabilities.toList()
            )
        }
    }
    
    /**
     * Cleans up all connections for an account.
     */
    override suspend fun disconnectAll(accountId: String) {
        val connectionsToRemove = connectionPool.filter { it.key.contains(accountId) }
        
        connectionsToRemove.forEach { (id, _) ->
            disconnect(id)
        }
        
        logger.i(TAG, "Disconnected ${connectionsToRemove.size} connections for account $accountId")
    }
    
    /**
     * Graceful shutdown of all connections.
     */
    fun shutdown() {
        runBlocking {
            connectionPool.keys.toList().forEach { id ->
                try {
                    disconnect(id)
                } catch (e: Exception) {
                    logger.w(TAG, "Error disconnecting $id during shutdown: ${e.message}")
                }
            }
        }
        logger.i(TAG, "IMAP client shutdown complete")
    }

    companion object {
        private const val TAG = "ImapClient"
    }
}

/**
 * Data class for connection statistics.
 */
data class ConnectionStats(
    val id: String,
    val host: String,
    val state: String,
    val uptimeMs: Long,
    val lastActivityMs: Long,
    val selectedFolder: String?,
    val capabilities: List<String>
)

/**
 * Enum representing IMAP flag operations.
 */
enum class FlagOperation(val imapPrefix: String) {
    ADD("+"),
    REMOVE("-"),
    ADD_SILENT("+"),
    REMOVE_SILENT("-"),
    REPLACE("")
}

/**
 * Mailbox update types from IDLE.
 */
data class MailboxUpdate(
    val type: UpdateType,
    val messageCount: Int = 0,
    val messageNumber: Int = 0,
    val recentCount: Int = 0,
    val flags: List<String> = emptyList(),
    val error: String? = null
)

enum class UpdateType {
    EXISTS,
    EXPUNGE,
    FLAGS_CHANGED,
    RECENT,
    POLL_REQUIRED,
    SERVER_BYE
}

/**
 * Fetch request configuration.
 */
data class FetchRequest(
    val uidRange: List<Long>? = null,
    val sequenceRange: List<Long>? = null,
    val limit: Int = 50,
    val includeFlags: Boolean = true,
    val includeInternalDate: Boolean = true,
    val includeSize: Boolean = true,
    val includeEnvelope: Boolean = true,
    val includeBodyStructure: Boolean = false,
    val bodyFetchType: BodyFetchType? = BodyFetchType.PEEK,
    val partialRange: Pair<Int, Int>? = null,
    val specificPart: String? = null,
    val sinceModSeq: Long? = null,
    val changedSince: Long? = null
)

enum class BodyFetchType {
    FULL,
    HEADER_ONLY,
    TEXT_ONLY,
    PEEK,
    PARTIAL,
    SPECIFIC_PART
}

/**
 * Search criteria for IMAP SEARCH.
 */
data class SearchCriteria(
    val text: String? = null,
    val subject: String? = null,
    val from: String? = null,
    val to: String? = null,
    val since: String? = null,
    val before: String? = null,
    val unseen: Boolean = false,
    val flagged: Boolean = false,
    val answered: Boolean = false,
    val deleted: Boolean = false,
    val draft: Boolean = false,
    val seen: Boolean = false,
    val largerThan: Int? = null,
    val smallerThan: Int? = null,
    val headers: Map<String, String>? = null,
    val logic: SearchLogic = SearchLogic.AND
)

enum class SearchLogic {
    AND,
    OR,
    NOT
}

data class FetchResult(
    val messages: List<EmailMessage>,
    val hasMore: Boolean
)

data class AuthToken(
    val accessToken: String,
    val refreshToken: String? = null,
    val expiryTime: Long? = null,
    val authType: AuthType
)