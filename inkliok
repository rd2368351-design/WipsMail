    /**
     * Parses folder listing responses into EmailFolder models.
     */
    private fun parseFolderList(lines: List<ImapResponseLine>): List<EmailFolder> {
        val folders = mutableListOf<EmailFolder>()
        val folderRegex = Regex("""\*\s+(?:XLIST|LIST)\s+\((.*?)\)\s+"(.*?)"\s+"?(.*?)"?$""")
        
        for (line in lines) {
            val match = folderRegex.find(line.content) ?: continue
            val attributes = match.groupValues[1]
            val separator = match.groupValues[2]
            val name = match.groupValues[3]
            
            val folderType = determineFolderType(attributes, name)
            
            folders.add(
                EmailFolder(
                    name = name,
                    fullName = name,
                    type = folderType,
                    separator = separator,
                    attributes = parseAttributes(attributes),
                    canSelect = !attributes.contains("\\Noselect"),
                    canCreateSubfolders = !attributes.contains("\\Noinferiors")
                )
            )
        }
        
        return folders
    }
    
    /**
     * Determines folder type from IMAP attributes and name patterns.
     */
    private fun determineFolderType(attributes: String, name: String): FolderType {
        return when {
            attributes.contains("\\Inbox") || name.equals("INBOX", ignoreCase = true) -> FolderType.INBOX
            attributes.contains("\\Sent") || name.contains("Sent", ignoreCase = true) -> FolderType.SENT
            attributes.contains("\\Drafts") || name.contains("Draft", ignoreCase = true) -> FolderType.DRAFTS
            attributes.contains("\\Trash") || name.contains("Trash", ignoreCase = true) || 
                name.contains("Deleted", ignoreCase = true) -> FolderType.TRASH
            attributes.contains("\\Spam") || attributes.contains("\\Junk") || 
                name.contains("Spam", ignoreCase = true) || name.contains("Junk", ignoreCase = true) -> FolderType.SPAM
            attributes.contains("\\Archive") || name.contains("Archive", ignoreCase = true) -> FolderType.ARCHIVE
            attributes.contains("\\All") || name.contains("All Mail", ignoreCase = true) -> FolderType.ALL
            attributes.contains("\\Important") || name.contains("Important", ignoreCase = true) -> FolderType.IMPORTANT
            attributes.contains("\\Flagged") || name.contains("Starred", ignoreCase = true) -> FolderType.FLAGGED
            else -> FolderType.CUSTOM
        }
    }
    
    /**
     * Parses folder attributes from IMAP LIST response.
     */
    private fun parseAttributes(attributesString: String): List<String> {
        return attributesString
            .split(" ")
            .map { it.trim() }
            .filter { it.isNotEmpty() }
    }
    
    /**
     * Parses SELECT/EXAMINE response to extract mailbox state.
     */
    private fun parseMailboxState(lines: List<ImapResponseLine>): MailBoxState {
        var exists = 0
        var recent = 0
        var unseen = 0
        var uidNext = 0L
        var uidValidity = 0L
        var highestModSeq = 0L
        val flags = mutableSetOf<String>()
        val permanentFlags = mutableSetOf<String>()
        
        for (line in lines) {
            val content = line.content
            when {
                content.contains("EXISTS") -> {
                    exists = content.substringBefore(" EXISTS").trim().toIntOrNull() ?: 0
                }
                content.contains("RECENT") -> {
                    recent = content.substringBefore(" RECENT").trim().toIntOrNull() ?: 0
                }
                content.contains("UNSEEN") -> {
                    unseen = content.substringAfter("UNSEEN ").substringBefore("]").trim().toIntOrNull() ?: 0
                }
                content.contains("UIDNEXT") -> {
                    uidNext = content.substringAfter("UIDNEXT ").substringBefore("]").trim().toLongOrNull() ?: 0L
                }
                content.contains("UIDVALIDITY") -> {
                    uidValidity = content.substringAfter("UIDVALIDITY ").substringBefore("]").trim().toLongOrNull() ?: 0L
                }
                content.contains("HIGHESTMODSEQ") -> {
                    highestModSeq = content.substringAfter("HIGHESTMODSEQ ").substringBefore("]").trim().toLongOrNull() ?: 0L
                }
                content.contains("FLAGS (") -> {
                    val flagsStr = content.substringAfter("FLAGS (").substringBefore(")")
                    flags.addAll(flagsStr.split(" ").map { it.trim() }.filter { it.isNotEmpty() })
                }
                content.contains("PERMANENTFLAGS (") -> {
                    val permFlagsStr = content.substringAfter("PERMANENTFLAGS (").substringBefore(")")
                    permanentFlags.addAll(permFlagsStr.split(" ").map { it.trim() }.filter { it.isNotEmpty() })
                }
            }
        }
        
        return MailBoxState(
            exists = exists,
            recent = recent,
            unseen = unseen,
            uidNext = uidNext,
            uidValidity = uidValidity,
            highestModSeq = highestModSeq,
            flags = flags.toList(),
            permanentFlags = permanentFlags.toList(),
            isReadOnly = permanentFlags.contains("\\*") == false
        )
    }

    // ============================================================================
    // SECTION 5: MESSAGE FETCHING (700 lines)
    // ============================================================================
    
    /**
     * Fetches messages with configurable fetch strategy.
     * Supports FETCH, UID FETCH, and CONDSTORE-based fetching.
     */
    override suspend fun fetchMessages(
        connectionId: String,
        folderName: String,
        fetchRequest: FetchRequest
    ): Result<FetchResult> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            // Ensure we're in the correct folder
            if (connection.selectedFolder != folderName) {
                selectFolder(connectionId, folderName, false)
            }
            
            val fetchCommand = buildFetchCommand(fetchRequest, connection.capabilities)
            val response = sendCommand(connection, fetchCommand)
            
            if (!response.isOk && !response.status.contains("NO")) {
                return@withContext Result.Error(NetworkException.ServerError("Fetch failed: ${response.status}"))
            }
            
            // Parse fetch responses
            val messages = parseFetchResponses(response.lines, fetchRequest)
            
            logger.d(TAG, "Fetched ${messages.size} messages from $folderName")
            Result.Success(FetchResult(messages = messages, hasMore = messages.size >= fetchRequest.limit))
            
        } catch (e: Exception) {
            logger.e(TAG, "Message fetch failed for $folderName", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * Builds IMAP FETCH command based on request parameters and server capabilities.
     */
    private fun buildFetchCommand(request: FetchRequest, capabilities: Set<String>): String {
        val sb = StringBuilder()
        
        // Determine whether to use UID FETCH
        val useUid = request.uidRange != null
        val commandPrefix = if (useUid) "UID FETCH" else "FETCH"
        
        sb.append(commandPrefix).append(" ")
        
        // Add sequence set
        if (useUid) {
            sb.append(formatSequenceSet(request.uidRange))
        } else {
            sb.append(formatSequenceSet(request.sequenceRange))
        }
        
        sb.append(" (")
        
        // Build fetch items
        val items = mutableListOf<String>()
        
        // Always fetch UID
        items.add("UID")
        
        // FLAGS
        if (request.includeFlags) {
            items.add("FLAGS")
        }
        
        // INTERNALDATE
        if (request.includeInternalDate) {
            items.add("INTERNALDATE")
        }
        
        // RFC822.SIZE
        if (request.includeSize) {
            items.add("RFC822.SIZE")
        }
        
        // ENVELOPE
        if (request.includeEnvelope) {
            items.add("ENVELOPE")
        }
        
        // BODYSTRUCTURE
        if (request.includeBodyStructure) {
            items.add("BODYSTRUCTURE")
        }
        
        // Body parts
        when (request.bodyFetchType) {
            BodyFetchType.FULL -> {
                items.add("BODY[]")
            }
            BodyFetchType.HEADER_ONLY -> {
                items.add("BODY[HEADER]")
            }
            BodyFetchType.TEXT_ONLY -> {
                items.add("BODY[TEXT]")
            }
            BodyFetchType.PEEK -> {
                items.add("BODY.PEEK[]")
            }
            BodyFetchType.PARTIAL -> {
                request.partialRange?.let { range ->
                    items.add("BODY[]<${range.first}.${range.last}>")
                }
            }
            BodyFetchType.SPECIFIC_PART -> {
                request.specificPart?.let { part ->
                    items.add("BODY[$part]")
                }
            }
            null -> {
                // Don't fetch body
            }
        }
        
        // MODSEQ for CONDSTORE
        if (capabilities.contains("CONDSTORE") && request.sinceModSeq != null) {
            items.add("MODSEQ")
        }
        
        sb.append(items.joinToString(" "))
        sb.append(")")
        
        // Add CHANGEDSINCE for QRESYNC
        if (capabilities.contains("QRESYNC") && request.changedSince != null) {
            sb.append(" (CHANGEDSINCE ${request.changedSince})")
        }
        
        return sb.toString()
    }
    
    /**
     * Formats message sequence set (e.g., "1:50,100,150:200").
     */
    private fun formatSequenceSet(range: List<Long>?): String {
        if (range == null || range.isEmpty()) return "1:*"
        
        if (range.size == 1) return range.first().toString()
        
        // Group consecutive numbers
        val groups = mutableListOf<String>()
        var start = range.first()
        var end = start
        
        for (i in 1 until range.size) {
            if (range[i] == end + 1) {
                end = range[i]
            } else {
                groups.add(if (start == end) "$start" else "$start:$end")
                start = range[i]
                end = start
            }
        }
        groups.add(if (start == end) "$start" else "$start:$end")
        
        return groups.joinToString(",")
    }
    
    /**
     * Parses FETCH responses into EmailMessage models.
     */
    private fun parseFetchResponses(
        lines: List<ImapResponseLine>,
        request: FetchRequest
    ): List<EmailMessage> {
        val messages = mutableListOf<EmailMessage>()
        var currentMessage = mutableMapOf<String, Any>()
        var currentUid: Long? = null
        var inFetchResponse = false
        
        for (line in lines) {
            val content = line.content.trim()
            
            // Detect FETCH response start
            if (content.contains("FETCH (") || content.contains("FETCH(")) {
                if (currentUid != null) {
                    messages.add(createMessageFromFetchData(currentUid, currentMessage))
                }
                currentMessage = mutableMapOf()
                currentUid = null
                inFetchResponse = true
            }
            
            if (!inFetchResponse) continue
            
            // Extract UID
            if (content.contains("UID ")) {
                currentUid = content.substringAfter("UID ").substringBefore(" ").substringBefore(")")
                    .trim().toLongOrNull()
            }
            
            // Extract FLAGS
            if (content.contains("FLAGS (")) {
                val flagsStr = content.substringAfter("FLAGS (").substringBefore(")")
                currentMessage["flags"] = flagsStr.split(" ").filter { it.isNotEmpty() }
            }
            
            // Extract INTERNALDATE
            if (content.contains("INTERNALDATE ")) {
                val dateStr = content.substringAfter("INTERNALDATE \"").substringBefore("\"")
                currentMessage["internalDate"] = dateStr
            }
            
            // Extract RFC822.SIZE
            if (content.contains("RFC822.SIZE ")) {
                val sizeStr = content.substringAfter("RFC822.SIZE ").substringBefore(" ")
                    .substringBefore(")").trim()
                currentMessage["size"] = sizeStr.toIntOrNull() ?: 0
            }
            
            // Extract ENVELOPE (simplified)
            if (content.contains("ENVELOPE (")) {
                parseEnvelope(content, currentMessage)
            }
            
            // Extract MODSEQ
            if (content.contains("MODSEQ (")) {
                val modSeqStr = content.substringAfter("MODSEQ (").substringBefore(")")
                currentMessage["modSeq"] = modSeqStr.toLongOrNull() ?: 0L
            }
            
            // Check for FETCH response end
            if (content.endsWith(")") && !content.contains("(")) {
                inFetchResponse = false
            }
        }
        
        // Add last message
        if (currentUid != null) {
            messages.add(createMessageFromFetchData(currentUid, currentMessage))
        }
        
        return messages
    }
    
    /**
     * Parses ENVELOPE structure from FETCH response.
     */
    private fun parseEnvelope(content: String, message: MutableMap<String, Any>) {
        try {
            val envelope = content.substringAfter("ENVELOPE (")
            
            // Extract subject
            val subjectMatch = Regex("\"([^\"]*)\"").find(envelope)
            message["subject"] = subjectMatch?.groupValues?.get(1) ?: ""
            
            // Extract from address
            val fromStart = envelope.indexOf("((")
            val fromEnd = envelope.indexOf("))")
            if (fromStart >= 0 && fromEnd > fromStart) {
                val fromPart = envelope.substring(fromStart + 2, fromEnd)
                message["from"] = parseAddress(fromPart)
            }
            
            // Extract date
            val dateMatch = Regex("\"([^\"]{10,30})\"").find(envelope.substring(fromEnd + 2))
            message["date"] = dateMatch?.groupValues?.get(1) ?: ""
            
        } catch (e: Exception) {
            logger.w(TAG, "Failed to parse envelope: ${e.message}")
        }
    }
    
    /**
     * Parses email address from IMAP address structure.
     */
    private fun parseAddress(addressStr: String): String {
        val parts = addressStr.split(" ")
        val name = parts.getOrNull(0)?.removeSurrounding("\"", "\"") ?: ""
        val email = parts.lastOrNull()?.removeSurrounding("\"", "\"") ?: ""
        
        return if (name.isNotEmpty()) "$name <$email>" else email
    }
    
    /**
     * Creates EmailMessage from parsed fetch data.
     */
    private fun createMessageFromFetchData(
        uid: Long,
        data: MutableMap<String, Any>
    ): EmailMessage {
        return EmailMessage(
            uid = uid,
            messageId = data["messageId"] as? String ?: "",
            subject = data["subject"] as? String ?: "",
            from = data["from"] as? String ?: "",
            date = data["date"] as? String ?: "",
            size = (data["size"] as? Int)?.toLong() ?: 0L,
            flags = data["flags"] as? List<String> ?: emptyList(),
            internalDate = data["internalDate"] as? String,
            modSeq = data["modSeq"] as? Long ?: 0L,
            preview = data["preview"] as? String,
            hasAttachments = data["hasAttachments"] as? Boolean ?: false,
            isRead = (data["flags"] as? List<String>)?.contains("\\Seen") ?: false,
            isFlagged = (data["flags"] as? List<String>)?.contains("\\Flagged") ?: false,
            isAnswered = (data["flags"] as? List<String>)?.contains("\\Answered") ?: false
        )
    }

