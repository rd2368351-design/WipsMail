    /**
     * Authenticates using the appropriate method based on account configuration
     * and server capabilities.
     */
    override suspend fun login(
        connectionId: String,
        account: EmailAccount
    ): Result<AuthToken> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            connection.state = ConnectionState.AUTHENTICATING
            
            val authResult = when (account.authType) {
                AuthType.OAUTH2 -> authenticateOAuth2(connection, account)
                AuthType.PASSWORD -> authenticatePassword(connection, account)
                AuthType.SASL_XOAUTH2 -> authenticateSaslXoauth2(connection, account)
                AuthType.APP_PASSWORD -> authenticateAppPassword(connection, account)
                AuthType.CLIENT_CERTIFICATE -> authenticateClientCert(connection, account)
                else -> throw NetworkException.AuthenticationFailed("Unsupported auth type: ${account.authType}")
            }
            
            connection.state = ConnectionState.AUTHENTICATED
            connection.lastActivity.set(System.currentTimeMillis())
            
            logger.i(TAG, "Authentication successful for ${account.email}")
            Result.Success(authResult)
            
        } catch (e: Exception) {
            logger.e(TAG, "Authentication failed for ${account.email}", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
    /**
     * OAuth2 authentication flow implementation.
     */
    private suspend fun authenticateOAuth2(
        connection: ImapConnection,
        account: EmailAccount
    ): AuthToken {
        // Validate OAuth2 credentials
        if (account.oauthAccessToken == null) {
            throw NetworkException.AuthenticationFailed("OAuth2 access token not available")
        }
        
        // Check if token needs refresh
        val token = if (isTokenExpired(account.oauthExpiryTime)) {
            refreshOAuthToken(account)
        } else {
            account.oauthAccessToken
        }
        
        // Construct SASL XOAUTH2 string
        val authString = buildString {
            append("user=").append(account.email).append("\u0001")
            append("auth=Bearer ").append(token).append("\u0001")
            append("\u0001")
        }
        
        val encodedAuth = java.util.Base64.getEncoder().encodeToString(authString.toByteArray())
        val command = "AUTHENTICATE XOAUTH2 $encodedAuth"
        
        val response = sendCommand(connection, command)
        
        if (!response.isOk) {
            throw NetworkException.AuthenticationFailed("OAuth2 authentication rejected: ${response.status}")
        }
        
        return AuthToken(
            accessToken = token,
            refreshToken = account.oauthRefreshToken,
            expiryTime = account.oauthExpiryTime ?: System.currentTimeMillis() + 3600000,
            authType = AuthType.OAUTH2
        )
    }
    
    /**
     * Standard password authentication.
     */
    private suspend fun authenticatePassword(
        connection: ImapConnection,
        account: EmailAccount
    ): AuthToken {
        val password = account.password ?: throw NetworkException.AuthenticationFailed("Password not provided")
        
        val loginCommand = "LOGIN \"${escapeQuoted(account.email)}\" \"${escapeQuoted(password)}\""
        val response = sendCommand(connection, loginCommand)
        
        if (!response.isOk) {
            // Check for specific error conditions
            if (response.status.contains("AUTHENTICATIONFAILED")) {
                throw NetworkException.AuthenticationFailed("Invalid credentials")
            } else if (response.status.contains("ALERT")) {
                val alertMsg = response.lines.firstOrNull { it.content.contains("ALERT") }?.content
                throw NetworkException.AuthenticationFailed("Server alert: $alertMsg")
            }
            throw NetworkException.AuthenticationFailed("Password authentication failed: ${response.status}")
        }
        
        return AuthToken(
            accessToken = password, // Store encrypted
            authType = AuthType.PASSWORD
        )
    }
    
    /**
     * SASL XOAUTH2 authentication (used by Gmail).
     */
    private suspend fun authenticateSaslXoauth2(
        connection: ImapConnection,
        account: EmailAccount
    ): AuthToken {
        val token = account.oauthAccessToken ?: throw NetworkException.AuthenticationFailed("Token required")
        
        val saslCommand = buildString {
            append("AUTHENTICATE XOAUTH2")
        }
        
        // Send initial auth command
        val initResponse = sendCommand(connection, saslCommand)
        
        if (initResponse.status.contains("+")) {
            // Server expects continuation with credentials
            val credentials = java.util.Base64.getEncoder().encodeToString(
                "user=${account.email}\u0001auth=Bearer $token\u0001\u0001".toByteArray()
            )
            val finalResponse = sendRawCommand(connection, credentials)
            
            if (!finalResponse.isOk) {
                throw NetworkException.AuthenticationFailed("SASL XOAUTH2 failed: ${finalResponse.status}")
            }
        } else if (!initResponse.isOk) {
            throw NetworkException.AuthenticationFailed("SASL XOAUTH2 failed: ${initResponse.status}")
        }
        
        return AuthToken(accessToken = token, authType = AuthType.SASL_XOAUTH2)
    }
    
    /**
     * Application-specific password authentication.
     */
    private suspend fun authenticateAppPassword(
        connection: ImapConnection,
        account: EmailAccount
    ): AuthToken {
        val appPassword = account.appPassword ?: throw NetworkException.AuthenticationFailed("App password not set")
        
        val loginCommand = "LOGIN \"${escapeQuoted(account.email)}\" \"${escapeQuoted(appPassword)}\""
        val response = sendCommand(connection, loginCommand)
        
        if (!response.isOk) {
            throw NetworkException.AuthenticationFailed("App password authentication failed")
        }
        
        return AuthToken(accessToken = appPassword, authType = AuthType.APP_PASSWORD)
    }
    
    /**
     * Client certificate authentication.
     */
    private suspend fun authenticateClientCert(
        connection: ImapConnection,
        account: EmailAccount
    ): AuthToken {
        // Certificate authentication happens at TLS level
        // This is handled by the TrustManager configured during connection
        if (connection.state != ConnectionState.TLS_ESTABLISHED) {
            throw NetworkException.AuthenticationFailed("TLS required for client certificate authentication")
        }
        
        // Verify certificate was accepted
        val verifyResponse = sendCommand(connection, "NOOP")
        if (!verifyResponse.isOk) {
            throw NetworkException.AuthenticationFailed("Certificate authentication failed")
        }
        
        return AuthToken(authType = AuthType.CLIENT_CERTIFICATE)
    }
    
    /**
     * Checks if OAuth2 token is expired or about to expire.
     */
    private fun isTokenExpired(expiryTime: Long?): Boolean {
        if (expiryTime == null) return true
        // Consider expired if less than 5 minutes remaining
        return System.currentTimeMillis() > (expiryTime - 300_000)
    }
    
