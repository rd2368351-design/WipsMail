    /**
     * Lists all available mailboxes/folders with hierarchy support.
     */
    override suspend fun listFolders(connectionId: String): Result<List<EmailFolder>> = withContext(dispatcher.io) {
        try {
            val connection = getConnection(connectionId)
                ?: return@withContext Result.Error(NetworkException.ConnectionLost("Connection $connectionId not found"))
            
            // Use XLIST if available (Gmail) or standard LIST
            val command = if (connection.capabilities.contains("XLIST")) {
                "XLIST \"\" \"*\""
            } else {
                "LIST \"\" \"*\""
            }
            
            val response = sendCommand(connection, command)
            
            if (!response.isOk) {
                return@withContext Result.Error(NetworkException.ServerError("Folder listing failed: ${response.status}"))
            }
            
            val folders = parseFolderList(response.lines)
            logger.d(TAG, "Found ${folders.size} folders")
            
            Result.Success(folders)
            
        } catch (e: Exception) {
            logger.e(TAG, "Folder listing failed", e)
            Result.Error(mapNetworkError(e))
        }
    }
    
